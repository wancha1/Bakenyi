# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Integration: Required for secure administrative actions, articles, and media storage.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Decap CMS GitHub OAuth Integration (Server-side Secrets)
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# Appwrite Integration
VITE_APPWRITE_ENDPOINT="https://syd.cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID="6a4798740009f5062fff"
VITE_APPWRITE_DATABASE_ID="bakenyi_db"
VITE_APPWRITE_USERS_COLLECTION_ID="users"
VITE_APPWRITE_NEWS_COLLECTION_ID="news"
VITE_APPWRITE_BLOGS_COLLECTION_ID="blogs"
VITE_APPWRITE_VLOGS_COLLECTION_ID="vlogs"
VITE_APPWRITE_GALLERY_COLLECTION_ID="gallery"
VITE_APPWRITE_CATEGORIES_COLLECTION_ID="categories"
VITE_APPWRITE_COMMENTS_COLLECTION_ID="comments"
VITE_APPWRITE_CONTRIBUTIONS_COLLECTION_ID="contributions"
VITE_APPWRITE_ARTICLES_COLLECTION_ID="articles"
VITE_APPWRITE_STORAGE_BUCKET_ID="bakenyi_bucket"


