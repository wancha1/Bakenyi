{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user cultural profiles and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["contributor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "User submitted cultural data (photos, stories, audio placeholders).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["photo", "audio", "story"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "title", "status", "submittedAt"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Approved items displayed in the public gallery.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "contributionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "imageUrl", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "Published news articles, announcements, and heritage writings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Community News", "Culture", "Heritage", "Leadership", "History", "Announcements"] },
        "author": { "type": "string" },
        "publishedAt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "popular": { "type": "boolean" },
        "views": { "type": "number" },
        "tags": { "type": "array" }
      },
      "required": ["id", "title", "excerpt", "content", "category", "author", "publishedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profiles."
    },
    "contributions/{contributionId}": {
      "schema": "Contribution",
      "description": "Submitted contributions."
    },
    "gallery/{galleryItemId}": {
      "schema": "GalleryItem",
      "description": "Public gallery items."
    },
    "articles/{articleId}": {
      "schema": "Article",
      "description": "Public published articles and news."
    }
  }
}
