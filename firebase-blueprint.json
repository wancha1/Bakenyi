{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profiles with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "editor", "reporter"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "NewsBlogItem": {
      "title": "News and Blog Content",
      "description": "Represents a published or draft news article or blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "featuredImage": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array" },
        "status": { "type": "string", "enum": ["draft", "pending", "published"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "summary", "content", "authorId", "status", "createdAt"]
    },
    "VlogItem": {
      "title": "Vlog Item",
      "description": "Represents a video blog entry referencing a YouTube link.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "thumbnailImage": { "type": "string", "format": "uri" },
        "youtubeUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "youtubeUrl", "publishDate"]
    },
    "GalleryAlbum": {
      "title": "Gallery Album",
      "description": "Represents a collection of photos uploaded for a specific event with captions.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "images", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Represents a category for organizing news, blogs, and other publications.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Secure user roles and access control document."
    },
    "news/{newsId}": {
      "schema": "NewsBlogItem",
      "description": "News articles."
    },
    "blogs/{blogId}": {
      "schema": "NewsBlogItem",
      "description": "Blog posts."
    },
    "vlogs/{vlogId}": {
      "schema": "VlogItem",
      "description": "Video blogs (vlogs)."
    },
    "gallery/{galleryId}": {
      "schema": "GalleryAlbum",
      "description": "Public multi-photo gallery events with captions."
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Article and blog categories."
    }
  }
}
