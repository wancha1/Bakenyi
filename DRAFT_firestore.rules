rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role Lookup from authoritatively stored user documents
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Zero-Trust Role Authorization Inheritances
    function isSuperAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'wanchaaaron@gmail.com' && isEmailVerified()) ||
        (hasUserDoc() && getUserRole() == 'super_admin')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (hasUserDoc() && getUserRole() == 'admin')
      );
    }

    function isEditor() {
      return isSignedIn() && (
        isAdmin() ||
        (hasUserDoc() && getUserRole() == 'editor')
      );
    }

    function isReporter() {
      return isSignedIn() && (
        isEditor() ||
        (hasUserDoc() && getUserRole() == 'reporter')
      );
    }

    // --- Entity Validation Blueprints ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'status', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['super_admin', 'admin', 'editor', 'reporter'] &&
             data.status is string && data.status.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidNewsBlogItem(data) {
      return data.keys().hasAll(['title', 'slug', 'summary', 'content', 'authorId', 'authorName', 'category', 'tags', 'status', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() <= 120 &&
             data.summary is string && data.summary.size() <= 1000 &&
             data.content is string && data.content.size() <= 50000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 150 &&
             data.category is string && data.category.size() <= 100 &&
             data.tags is list && data.tags.size() <= 20 &&
             data.status in ['draft', 'pending', 'published'] &&
             data.createdAt == request.time;
    }

    function isValidVlog(data) {
      return data.keys().hasAll(['title', 'thumbnailImage', 'youtubeUrl', 'description', 'publishDate']) &&
             data.title is string && data.title.size() <= 200 &&
             data.thumbnailImage is string && data.thumbnailImage.size() <= 1000 &&
             data.youtubeUrl is string && data.youtubeUrl.size() <= 1000 &&
             data.description is string && data.description.size() <= 5000;
    }

    function isValidGalleryAlbum(data) {
      return data.keys().hasAll(['title', 'images', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.images is list && data.images.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.slug is string && data.slug.size() <= 100 &&
             data.createdAt == request.time;
    }

    // --- Match Rules Blocks ---

    // 1. Users Profiles (PII Isolation & Self-Privilege Guard)
    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || isAdmin();
      allow list: if isSuperAdmin();
      allow create: if isOwner(userId) && isEmailVerified() && isValidUserProfile(incoming()) && (
        // Prevent self-assigned roles: standard registrations must be reporter, except the core bootstrap admin
        (request.auth.token.email == 'wanchaaaron@gmail.com' && incoming().role == 'super_admin') ||
        incoming().role == 'reporter'
      );
      allow update: if isSuperAdmin() || (
        isOwner(userId) && 
        isValidUserProfile(incoming()) &&
        // Protect role and status from unauthorized changes
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
      );
    }

    // Helper validating News & Blog writes depending on specific author role constraints
    function authWriteNewsBlog(data, isCreate) {
      return isReporter() && isValidNewsBlogItem(data) && (
        // Reporters can only write as 'draft'
        (getUserRole() == 'reporter' && data.status == 'draft') ||
        // Editors can write 'draft' or 'pending' review
        (getUserRole() == 'editor' && data.status in ['draft', 'pending']) ||
        // Admins & Super Admins can write any status
        isAdmin()
      );
    }

    // 2. News Collection
    match /news/{newsId} {
      allow get: if resource.data.status == 'published' || isReporter();
      allow list: if resource.data.status == 'published' || isReporter();
      allow create: if isReporter() && isValidId(newsId) && authWriteNewsBlog(incoming(), true);
      allow update: if isReporter() && isValidId(newsId) && (
        // Immutable values guard
        incoming().createdAt == existing().createdAt &&
        incoming().authorId == existing().authorId && (
          // Admin override
          isAdmin() || (
            // Editor / Reporter constraints
            isOwner(existing().authorId) &&
            authWriteNewsBlog(incoming(), false) && (
              // If Reporter: can only update drafts
              (getUserRole() == 'reporter' && existing().status == 'draft') ||
              // If Editor: can update draft or pending review
              (getUserRole() == 'editor' && existing().status in ['draft', 'pending'])
            )
          )
        )
      );
      allow delete: if isAdmin();
    }

    // 3. Blogs Collection
    match /blogs/{blogId} {
      allow get: if resource.data.status == 'published' || isReporter();
      allow list: if resource.data.status == 'published' || isReporter();
      allow create: if isReporter() && isValidId(blogId) && authWriteNewsBlog(incoming(), true);
      allow update: if isReporter() && isValidId(blogId) && (
        // Immutable values guard
        incoming().createdAt == existing().createdAt &&
        incoming().authorId == existing().authorId && (
          // Admin override
          isAdmin() || (
            // Editor / Reporter constraints
            isOwner(existing().authorId) &&
            authWriteNewsBlog(incoming(), false) && (
              // If Reporter: can only update drafts
              (getUserRole() == 'reporter' && existing().status == 'draft') ||
              // If Editor: can update draft or pending review
              (getUserRole() == 'editor' && existing().status in ['draft', 'pending'])
            )
          )
        )
      );
      allow delete: if isAdmin();
    }

    // 4. Vlogs Collection
    match /vlogs/{vlogId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(vlogId) && isValidVlog(incoming());
      allow update: if isAdmin() && isValidId(vlogId) && isValidVlog(incoming());
      allow delete: if isAdmin();
    }

    // 5. Gallery Collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow create: if isReporter() && isValidId(galleryId) && isValidGalleryAlbum(incoming());
      allow update: if isReporter() && isValidId(galleryId) && isValidGalleryAlbum(incoming());
      allow delete: if isAdmin();
    }

    // 6. Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if isAdmin();
    }
  }
}
