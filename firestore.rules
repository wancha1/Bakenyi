rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role Lookup from authoritatively stored user documents
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Zero-Trust Role Authorization Inheritances
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'wanchaaaron@gmail.com' ||
        (hasUserDoc() && getUserRole() == 'super_admin')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (hasUserDoc() && getUserRole() == 'admin')
      );
    }

    function isEditor() {
      return isSignedIn() && (
        isAdmin() ||
        (hasUserDoc() && getUserRole() == 'editor')
      );
    }

    function isReporter() {
      return isSignedIn() && (
        isEditor() ||
        (hasUserDoc() && getUserRole() == 'reporter')
      );
    }

    // 1. Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Users Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isSuperAdmin() || isAdmin());
      allow create: if isOwner(userId) && (
        incoming().role == 'reporter' ||
        (incoming().role == 'super_admin' && (request.auth.token.email == 'wanchaaaron@gmail.com' || request.auth.uid == 'Lp09nUjMh7M5yeqE1Dih85k1qXI2' || userId == 'Lp09nUjMh7M5yeqE1Dih85k1qXI2'))
      );
      allow update: if isSuperAdmin() || (
        isOwner(userId) && 
        incoming().role == existing().role
      );
      allow delete: if isSuperAdmin();
    }

    // 3. News Collection
    match /news/{newsId} {
      allow read: if resource.data.status == 'published' || isReporter();
      allow create: if isReporter() && (
        isAdmin() ||
        (isEditor() && incoming().status in ['draft', 'pending']) ||
        (isReporter() && incoming().status == 'draft')
      );
      allow update: if isReporter() && (
        isAdmin() ||
        // Editors can update drafts and pending articles
        (isEditor() && existing().status in ['draft', 'pending'] && incoming().status in ['draft', 'pending']) ||
        // Reporters can only update their own drafts
        (isReporter() && existing().authorId == request.auth.uid && existing().status == 'draft' && incoming().status == 'draft')
      );
      allow delete: if isAdmin();
    }

    // 4. Blogs Collection
    match /blogs/{blogId} {
      allow read: if resource.data.status == 'published' || isReporter();
      allow create: if isReporter() && (
        isAdmin() ||
        (isEditor() && incoming().status in ['draft', 'pending']) ||
        (isReporter() && incoming().status == 'draft')
      );
      allow update: if isReporter() && (
        isAdmin() ||
        // Editors can update drafts and pending articles
        (isEditor() && existing().status in ['draft', 'pending'] && incoming().status in ['draft', 'pending']) ||
        // Reporters can only update their own drafts
        (isReporter() && existing().authorId == request.auth.uid && existing().status == 'draft' && incoming().status == 'draft')
      );
      allow delete: if isAdmin();
    }

    // 5. Vlogs Collection
    match /vlogs/{vlogId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 6. Gallery Collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow create: if isReporter();
      allow update: if isReporter();
      allow delete: if isAdmin();
    }

    // 7. Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
